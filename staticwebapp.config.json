{
  "globalHeaders": {
    "Cache-Control": "public, max-age=86400"
  },
  "routes": [
    {
      "route": "/CNC website/*.webp",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/CNC website/*.png",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/CNC website/*.jpeg",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/CNC website/*.svg",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "*.css",
      "headers": {
        "Cache-Control": "public, max-age=604800"
      }
    },
    {
      "route": "*.js",
      "headers": {
        "Cache-Control": "public, max-age=604800"
      }
    }
  ]
}
